{
  "name": "@manzt/quiver",
  "version": "2.3.0",
  "exports": {
    ".": "./src/mod.ts",
    "./flechette": "./src/flechette/mod.ts",
    "./apache-arrow": "./src/apache-arrow/mod.ts"
  },
  "license": "MIT",
  "nodeModulesDir": "auto",
  "test": {
    "exclude": ["src/__tests__/*"]
  },
  "tasks": {
    "test": "deno run -A vitest run",
    "test:update": "deno run -A vitest run --update"
  },
  "lint": {
    "rules": {
      "exclude": ["ban-types", "no-explicit-any"]
    }
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@uwdata/flechette": "npm:@uwdata/flechette@^2.3.0",
    "apache-arrow": "npm:apache-arrow@^21.1.0",
    "magic-string": "npm:magic-string@^0.30.21",
    "tintype": "npm:tintype@^0.0.1",
    "typescript": "npm:typescript@^6.0.2",
    "vitest": "npm:vitest@^4.1.2"
  }
}
